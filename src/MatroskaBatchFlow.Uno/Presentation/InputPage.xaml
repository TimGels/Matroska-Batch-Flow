<Page
    x:Class="MatroskaBatchFlow.Uno.Presentation.InputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MatroskaBatchFlow.Uno.Presentation"
    xmlns:controls="using:MatroskaBatchFlow.Uno.Presentation.Controls"
    xmlns:converters="using:MatroskaBatchFlow.Uno.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:Actions="using:MatroskaBatchFlow.Uno.Behavior"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="http://uno.ui/skia"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d skia"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <converters:IntThresholdToVisibilityConverter x:Key="IntThresholdToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Validation InfoBar -->
        <InfoBar x:Name="ValidationInfoBar"
                 Grid.Column="1"
                 Grid.Row="0"
                 Visibility="{x:Bind ViewModel.ValidationInfoBarVisibility, Mode=OneWay}"
                 IsOpen="{x:Bind ViewModel.IsValidationInfoBarOpen, Mode=TwoWay}"
                 Severity="{x:Bind ViewModel.ValidationInfoBarSeverity, Mode=OneWay}"
                 Title="{x:Bind ViewModel.ValidationSummaryTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.ValidationSummaryMessage, Mode=OneWay}"
                 IsClosable="True"
                 Margin="0,-16,0,28"
                 AutomationProperties.Name="Validation notifications"
                 AutomationProperties.LiveSetting="Polite">
            <InfoBar.ActionButton>
                <Button Content="View Details"
                        Command="{x:Bind ViewModel.ShowValidationDetailsCommand}"
                        AutomationProperties.Name="View validation details" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- CommandBar with actions for file list view-->
        <StackPanel Grid.Column="1"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    skia:Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                    win:Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondary}"
                    Margin="0,-16,0,12"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CommandBar Grid.Column="0"
                            DefaultLabelPosition="Right"
                            HorizontalAlignment="Left"
                            Width="Auto">
                    <CommandBar.PrimaryCommands>
                        <AppBarButton Icon="Add"
                                      Command="{x:Bind ViewModel.AddFilesCommand}"
                                      Label="Add Files" />
                        <AppBarSeparator />
                        <AppBarButton Icon="SelectAll"
                                      Label="Select All"
                                      IsEnabled="{x:Bind ViewModel.CanSelectAll, Mode=OneWay}"
                                      Command="{x:Bind ViewModel.SelectAll}"
                                      LabelPosition="Collapsed" />
                        <AppBarButton Icon="ClearSelection"
                                      Label="Undo Selection"
                                      IsEnabled="{x:Bind ViewModel.SelectedFiles.Count, Mode=OneWay, Converter={StaticResource GreaterThanZeroConverter}}"
                                      Command="{x:Bind ViewModel.ClearSelection}"
                                      LabelPosition="Collapsed" />
                    </CommandBar.PrimaryCommands>
                </CommandBar>

                <!-- Right CommandBar-->
                <CommandBar Grid.Column="1"
                            DefaultLabelPosition="Right"
                            HorizontalAlignment="Right">
                    <CommandBar.PrimaryCommands>
                        <AppBarButton Icon="Remove"
                                      Label="Remove"
                                      IsEnabled="{x:Bind ViewModel.SelectedFiles.Count, Mode=OneWay, Converter={StaticResource GreaterThanZeroConverter}}"
                                      Command="{x:Bind ViewModel.RemoveSelected}" />
                        <AppBarSeparator />
                        <AppBarButton Label="Clear"
                                      IsEnabled="{x:Bind ViewModel.FileList.Count, Mode=OneWay, Converter={StaticResource GreaterThanZeroConverter}}"
                                      Command="{x:Bind ViewModel.RemoveAll}">
                            <FontIcon Glyph="&#xEA99;" />
                        </AppBarButton>
                    </CommandBar.PrimaryCommands>
                </CommandBar>
            </Grid>
        </StackPanel>

        <Grid Grid.Column="1"
              Grid.Row="2">
            <ListView x:Name="FileDropListView"
                      skia:Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                      win:Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondary}"
                      CornerRadius="{ThemeResource ControlCornerRadius}"
                      Actions:DropFilesBehavior.IsEnabled="True"
                      Actions:DropFilesBehavior.FileDropTarget="{x:Bind ViewModel}"
                      ItemsSource="{x:Bind ViewModel.FileList}"
                      AllowDrop="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollMode="Enabled"
                      HorizontalContentAlignment="Stretch"
                      SelectionMode="Extended"
                      Actions:ListViewSelectedItemsBehavior.BoundSelectedItems="{x:Bind ViewModel.SelectedFiles, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ScannedFileViewModel">
                        <Grid Margin="0,6,0,6">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Delete"
                                                    Command="{x:Bind RemoveSelf}" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <TextBlock HorizontalAlignment="Left"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind FileInfo.Path}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel IsHitTestVisible="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.2"
                        Visibility="{x:Bind ViewModel.FileList.Count, Mode=OneWay, Converter={StaticResource IntThresholdToVisibilityConverter}, ConverterParameter='1;Collapsed;Visible'}">
                <TextBlock Text="Drag &amp; Drop here"
                           Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>

            <controls:InputOperationOverlay IsActive="{x:Bind ViewModel.OverlayState.IsActive, Mode=OneWay}"
                                            Message="{x:Bind ViewModel.OverlayState.Message, Mode=OneWay}"
                                            IsIndeterminate="{x:Bind ViewModel.OverlayState.IsIndeterminate, Mode=OneWay}"
                                            Current="{x:Bind ViewModel.OverlayState.Current, Mode=OneWay}"
                                            Total="{x:Bind ViewModel.OverlayState.Total, Mode=OneWay}"
                                            BlocksInput="{x:Bind ViewModel.OverlayState.BlocksInput, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
